# Supabase credentials — copy this file to ".env" and fill in your values.
# Find these in your Supabase project: Settings → API
#
#   VITE_SUPABASE_URL      = Project URL          (e.g. https://abcdxyz.supabase.co)
#   VITE_SUPABASE_ANON_KEY = Project API key → "anon / public"
#
# The .env file is git-ignored. NEVER commit real keys.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional store details surfaced on the public site, contact page, and PDF bills.
# Safe to commit — these are public-facing. Leave blank to use in-app placeholders.
VITE_STORE_PHONE=
VITE_STORE_WHATSAPP=
VITE_STORE_ADDRESS=
VITE_STORE_GST=
VITE_STORE_MAPS_EMBED=

# Developer Settings — comma-separated lists of additional authorized owners (optional)
# vkartheek0000@gmail.com and +919381861672 are already hardcoded, but you can add more here.
VITE_OWNER_EMAILS=
VITE_OWNER_PHONES=

